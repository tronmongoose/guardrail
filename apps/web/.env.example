# ── Database ──────────────────────────────────────────────────────────────────
# Neon in prod; use docker-compose.yml locally (port 5433)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── File Storage (Vercel Blob) ────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# If absent, emails are logged to console in dev and silently dropped in prod
RESEND_API_KEY=re_...
# Must match a verified domain in your Resend account
EMAIL_FROM=GuideRail <noreply@yourdomain.com>

# ── AI ────────────────────────────────────────────────────────────────────────
# LLM_PROVIDER: stub | anthropic | openai  (stub = no API calls, safe for dev)
LLM_PROVIDER=stub
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
HUGGINGFACEHUB_API_TOKEN=hf_...
GOOGLE_AI_API_KEY=...

# ── Video (Mux) ───────────────────────────────────────────────────────────────
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_WEBHOOK_SECRET=your_mux_webhook_secret

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated Clerk user IDs that can access /admin (transaction dashboard)
# Find your Clerk user ID in the Clerk dashboard under Users
ADMIN_USER_IDS=user_abc123,user_def456

# ── Platform access ───────────────────────────────────────────────────────────
# Comma-separated promo codes (case-insensitive) that grant creators platform access
# Creators who enter one of these codes bypass the platform fee
PLATFORM_PROMO_CODES=JOURNEY
